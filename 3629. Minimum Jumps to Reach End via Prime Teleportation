3629. Minimum Jumps to Reach End via Prime Teleportation



import java.util.*;

class Solution {

    public int minJumps(int[] nums) {
        int n = nums.length;
        if (n == 1) return 0;

        int MAX = 1_000_000;


        int[] spf = new int[MAX + 1];

        for (int i = 0; i <= MAX; i++) {
            spf[i] = i;
        }

        for (int i = 2; i * i <= MAX; i++) {
            if (spf[i] == i) {
                for (int j = i * i; j <= MAX; j += i) {
                    if (spf[j] == j) {
                        spf[j] = i;
                    }
                }
            }
        }


        Map<Integer, List<Integer>> map = new HashMap<>();

        for (int i = 0; i < n; i++) {
            int x = nums[i];
            Set<Integer> set = new HashSet<>();

            while (x > 1) {
                int p = spf[x];
                set.add(p);

                while (x % p == 0) {
                    x /= p;
                }
            }

            for (int p : set) {
                map.computeIfAbsent(p, k -> new ArrayList<>()).add(i);
            }
        }

        Queue<Integer> q = new LinkedList<>();
        boolean[] vis = new boolean[n];

        q.offer(0);
        vis[0] = true;

        int steps = 0;

        while (!q.isEmpty()) {
            int size = q.size();

            while (size-- > 0) {
                int i = q.poll();

                if (i == n - 1) return steps;


                if (i - 1 >= 0 && !vis[i - 1]) {
                    vis[i - 1] = true;
                    q.offer(i - 1);
                }


                if (i + 1 < n && !vis[i + 1]) {
                    vis[i + 1] = true;
                    q.offer(i + 1);
                }


                int val = nums[i];

                if (val > 1 && spf[val] == val) {

                    List<Integer> next = map.get(val);

                    if (next != null) {
                        for (int idx : next) {
                            if (!vis[idx]) {
                                vis[idx] = true;
                                q.offer(idx);
                            }
                        }

                        map.remove(val);
                    }
                }
            }

            steps++;
        }

        return -1;
    }
}
